<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Employee Form View to add GitHub User field -->
    <record id="view_employee_form_inherit_github_user" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.github.user</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_repository_users" type="object" class="oe_stat_button" icon="fa-code-fork">
                    <div class="o_stat_info">
                        Repository Access
                        <span class="o_stat_value">
                            <field name="tw_repository_user_count" widget="statinfo" nolabel="1"/>
                        </span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>

