<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_repositories" model="ir.cron">
            <field name="name">TW: Sync Odoo.sh Repositories</field>
            <field name="model_id" ref="model_tw_odoo_sh_repository"/>
            <field name="state">code</field>
            <field name="code">model.action_synchronize_all_odoo_sh_repositories()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_check_blocked_until" model="ir.cron">
            <field name="name">TW: Check Blocked Until Reminders</field>
            <field name="model_id" ref="model_tw_odoo_sh_branch"/>
            <field name="state">code</field>
            <field name="code">model.action_check_blocked_until_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>

