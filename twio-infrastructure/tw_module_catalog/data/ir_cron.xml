<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_discovery_github" model="ir.cron">
            <field name="name">GitHub Catalog: Discovery (Queue Filler)</field>
            <field name="model_id" ref="model_tw_github_repo"/>
            <field name="state">code</field>
            <field name="code">model.action_discovery_cron()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="DateTime.now()"/>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <record id="ir_cron_process_sync_queue" model="ir.cron">
            <field name="name">GitHub Catalog: Queue Processor (Worker)</field>
            <field name="model_id" ref="model_tw_module_catalog"/>
            <field name="state">code</field>
            <field name="code">model.action_process_queue_cron()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="DateTime.now()"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="priority">10</field>
        </record>
    </data>
</odoo>

