<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="view_tw_github_repo_list" model="ir.ui.view">
        <field name="name">tw.github.repo.list</field>
        <field name="model">tw.github.repo</field>
        <field name="arch" type="xml">
            <list string="Github Repositories">
                <field name="name"/>
                <field name="tw_last_sync" optional="show"/>
                <field name="tw_module_count" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_tw_github_repo_form" model="ir.ui.view">
        <field name="name">tw.github.repo.blacklist.form</field>
        <field name="model">tw.github.repo.blacklist</field>
        <field name="arch" type="xml">
            <form string="Github Repository">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="tw_last_sync" readonly="1"/>
                            <field name="tw_module_count" readonly="1"/>
                            <field name="tw_branch" confirm="Are you sure you want to change the branch?"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action for the blacklist list view-->
    <record id="action_tw_github_repo" model="ir.actions.act_window">
        <field name="name">Github Repositories</field>
        <field name="res_model">tw.github.repo</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>