<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="view_tw_github_repo_list" model="ir.ui.view">
        <field name="name">tw.github.repo.list</field>
        <field name="model">tw.github.repo</field>
        <field name="arch" type="xml">
            <list string="Github Repositories">
                <field name="name"/>
                <field name="tw_last_sync" optional="show"/>
                <field name="tw_module_count" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_tw_github_repo_form" model="ir.ui.view">
        <field name="name">tw.github.repo.form</field>
        <field name="model">tw.github.repo</field>
        <field name="arch" type="xml">
            <form string="Github Repository">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="tw_last_sync" readonly="1"/>
                            <field name="tw_module_count" readonly="1"/>
                            <field name="tw_branch" placeholder="main" confirm="Are you sure you want to change the branch?"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="modules" string="Modules">
                            <field name="tw_module_ids" widget="sol_o2m" mode="list,kanban">
                                <list>
                                    <field name="tw_technical_name"/>
                                    <field name="tw_name"/>
                                    <field name="tw_version"/>
                                </list>
                            </field>
                        </page>
                        <page name="archived_modules" string="Archived Modules">
                            <field name="tw_archived_module_ids" mode="list" context="{'active_test': False}">
                                <list edit="0" create="0" delete="0">
                                    <field name="tw_technical_name"/>
                                    <field name="tw_name"/>
                                    <field name="tw_version"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action for the blacklist list view-->
    <record id="action_tw_github_repo" model="ir.actions.act_window">
        <field name="name">Github Repositories</field>
        <field name="res_model">tw.github.repo</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>