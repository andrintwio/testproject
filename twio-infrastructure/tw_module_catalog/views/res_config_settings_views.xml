<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_tw_module_catalog" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.tw_module_catalog</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='infrastructure']" position="inside">
                <block title="Module Catalog" name="tw_module_catalog_config">
                    <setting string="Module Catalog Configuration">
                        <div class="text-muted">
                            Configure your Github Token. This token is used to authenticate with the Github API and allow fetching repository data.
                        </div>
                        <div class="content-group">
                            <div class="row mt16">
                                <label for="tw_module_catalog_github_token" class="col-lg-3"/>
                                <field name="tw_module_catalog_github_token" password="1"/>
                            </div>
                            <div class="row mt16">
                                <label for="tw_module_catalog_github_org" class="col-lg-3"/>
                                <field name="tw_module_catalog_github_org"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
