<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.form.inherit.tw_pdf_customizations</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
			<xpath expr="//group[@name='sale_info_group']" position="inside">
				<field name="tw_dimension"/>
                <label for="tw_gross_weight"/>
                <div class="o_row">
                    <field name="tw_gross_weight" class="oe_inline" style="max-width: 7rem;"/>
                    <span>kg</span>
                </div>
			</xpath>
		</field>
	</record>
</odoo>
