<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_picking_withcarrier_out_form" model="ir.ui.view">
        <field name="name">delivery.stock.picking_withcarrier.form.view.inherit.tw_pdf_customizations</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock_delivery.view_picking_withcarrier_out_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='shipping_weight']/.." position="after">
                <label for="tw_gross_weight"/>
                <div class="o_row">
                    <field name="tw_gross_weight" class="oe_inline" style="max-width: 7rem;"/>
                    <span>kg</span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
