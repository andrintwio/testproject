<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_order_form_with_carrier" model="ir.ui.view">
        <field name="name">delivery.sale.order.form.inherit.tw_pdf_customizations</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="delivery.view_order_form_with_carrier"/>
        <field name="arch" type="xml">
			<xpath expr="//field[@name='shipping_weight']" position="after">
				<label for="tw_gross_weight"/>
                <div class="o_row">
                    <field name="tw_gross_weight" class="oe_inline" style="max-width: 7rem;"/>
                    <span>kg</span>
                </div>
                <field name="tw_dimension"/>
			</xpath>
		</field>
	</record>
</odoo>
